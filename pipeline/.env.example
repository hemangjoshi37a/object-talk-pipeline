# Copy this file to `.env` and fill in your values.
# (You can also configure everything from the in-app Settings page at /settings.)

# Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...your-key-here

# Gemini model IDs. The defaults work; change only if you have a reason.
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# YouTube OAuth — where to read/write the cached token + downloaded client secret.
# The Settings page can also write the client_secret.json for you.
YOUTUBE_TOKEN_PATH=~/.youtube-mcp/token.json
YOUTUBE_CLIENT_SECRET=~/.youtube-mcp/client_secret.json

# Grok persistent browser profile (Chromium user-data-dir for cached login).
# Default keeps it inside the project tree; change if you want it elsewhere.
GROK_PROFILE_DIR=./browser_data/grok
